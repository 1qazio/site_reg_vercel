{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/",
      "destination": "/api/index.py"
    },
    {
      "source": "/state",
      "destination": "/api/index.py"
    },
    {
      "source": "/register",
      "destination": "/api/index.py"
    },
    {
      "source": "/bookings",
      "destination": "/api/index.py"
    },
    {
      "source": "/bookings/:path*",
      "destination": "/api/index.py"
    },
    {
      "source": "/api/:path*",
      "destination": "/api/index.py"
    }
  ]
}
